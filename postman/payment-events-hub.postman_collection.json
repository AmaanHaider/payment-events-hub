{
  "info": {
    "name": "payment-events-hub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "GET /health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health",
        "description": "DB connectivity + row counts. Response includes: status, database, event_count, transaction_count."
      }
    },
    {
      "name": "POST /events (sample)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_id\": \"00000000-0000-0000-0000-000000000001\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"00000000-0000-0000-0000-0000000000aa\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": 10.0,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-01T00:00:00+00:00\"\n}\n"
        },
        "url": "{{baseUrl}}/events"
      }
    },
    {
      "name": "POST /events (duplicate with conflict)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_id\": \"00000000-0000-0000-0000-000000000001\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"00000000-0000-0000-0000-0000000000aa\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": 99.99,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-01-01T00:00:00+00:00\"\n}\n"
        },
        "url": "{{baseUrl}}/events",
        "description": "Reuses the same event_id as the sample request but changes amount. Expect accepted=false, duplicate=true, conflict=true, and conflict_fields includes amount."
      }
    },
    {
      "name": "GET /transactions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/transactions?limit=50&offset=0&sort=updated_at&direction=desc",
          "host": ["{{baseUrl}}"],
          "path": ["transactions"],
          "query": [
            { "key": "merchant_id", "value": "merchant_1", "disabled": true },
            { "key": "status", "value": "processed", "disabled": true },
            { "key": "from_date", "value": "2026-01-01T00:00:00+00:00", "disabled": true },
            { "key": "to_date", "value": "2027-01-01T00:00:00+00:00", "disabled": true },
            { "key": "limit", "value": "50" },
            { "key": "offset", "value": "0" },
            { "key": "sort", "value": "updated_at" },
            { "key": "direction", "value": "desc" }
          ]
        }
      }
    },
    {
      "name": "GET /transactions/{transaction_id}",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/transactions/00000000-0000-0000-0000-0000000000aa"
      }
    },
    {
      "name": "GET /reconciliation/summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/reconciliation/summary?group_by=merchant",
          "host": ["{{baseUrl}}"],
          "path": ["reconciliation", "summary"],
          "query": [
            { "key": "group_by", "value": "merchant" },
            { "key": "merchant_id", "value": "merchant_1", "disabled": true },
            { "key": "from_date", "value": "2026-01-01T00:00:00+00:00", "disabled": true },
            { "key": "to_date", "value": "2027-01-01T00:00:00+00:00", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "GET /reconciliation/discrepancies",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/reconciliation/discrepancies?limit=50&offset=0",
          "host": ["{{baseUrl}}"],
          "path": ["reconciliation", "discrepancies"],
          "query": [
            { "key": "merchant_id", "value": "merchant_1", "disabled": true },
            {
              "key": "type",
              "value": "settled_after_failed",
              "disabled": true,
              "description": "Optional: payment_terminal_conflict | processed_not_settled | settled_after_failed | settled_without_terminal_payment_outcome"
            },
            { "key": "limit", "value": "50" },
            { "key": "offset", "value": "0" }
          ]
        },
        "description": "Returns { items, summary: { total, by_type }, page: { limit, offset, total } }."
      }
    }
  ]
}
